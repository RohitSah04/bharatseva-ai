# .env.example
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.

# ── Application ──────────────────────────────────────────────
APP_ENV=development
# Options: development | staging | production

LOG_FORMAT=pretty
# Options: json | pretty  (use "json" in staging + production)

# ── Flask ─────────────────────────────────────────────────────
FLASK_APP=backend/app
FLASK_DEBUG=1
# Set FLASK_DEBUG=0 in production

SECRET_KEY=replace_with_at_least_32_random_chars

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET_KEY=replace_with_at_least_32_random_chars
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=900
JWT_REFRESH_TOKEN_EXPIRES_SECONDS=604800

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/bharatseva.db
# Phase 2: postgresql+psycopg2://user:pass@host:5432/bharatseva

# ── Security ──────────────────────────────────────────────────
BCRYPT_COST=12
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── IBM watsonx.ai ────────────────────────────────────────────
WATSONX_API_KEY=your_ibm_cloud_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_CHAT=ibm/granite-13b-chat-v2
WATSONX_MODEL_INSTRUCT=ibm/granite-13b-instruct-v2
WATSONX_TIMEOUT_SECONDS=15

# ── Vector Store ──────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
# Phase 2: VECTOR_STORE_URL=<managed-milvus-or-watsonx-discovery-url>

# ── Rate Limiting ─────────────────────────────────────────────
RATELIMIT_STORAGE_URI=memory://
# Phase 2: RATELIMIT_STORAGE_URI=redis://localhost:6379/0

# ── Feature Flags ─────────────────────────────────────────────
# Feature flags are managed at runtime via /api/v1/admin/feature-flags
# Seed defaults are in backend/config/feature_flag_seeds.json

# ── Frontend (prefix VITE_ for Vite) ─────────────────────────
VITE_API_BASE_URL=http://localhost:5000
