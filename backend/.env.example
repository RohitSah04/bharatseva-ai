# BharatSeva AI — Backend environment variables
# Copy to .env and fill in real values. NEVER commit .env.

APP_ENV=development
LOG_FORMAT=pretty

FLASK_APP=run.py
FLASK_DEBUG=1
SECRET_KEY=change-me-at-least-32-random-characters-here

JWT_SECRET_KEY=change-me-jwt-at-least-32-random-chars
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=900
JWT_REFRESH_TOKEN_EXPIRES_SECONDS=604800

DATABASE_URL=sqlite:///./data/bharatseva.db

BCRYPT_COST=12
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

WATSONX_API_KEY=xPBw36kWN5RCw6nwt_3njDzqNmaPX22R91ep-t-PEJjj
WATSONX_PROJECT_ID=1f5cbdbb-e0c7-46fb-81b7-b0f908f879f0
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_CHAT=ibm/granite-4-h-small
WATSONX_MODEL_INSTRUCT=ibm/granite-4-h-small
WATSONX_TIMEOUT_SECONDS=30

CACHE_TYPE=SimpleCache
CACHE_DEFAULT_TIMEOUT=300

UPLOAD_FOLDER=./data/uploads
