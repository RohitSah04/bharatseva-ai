# BharatSeva AI — Backend environment variables
# Copy to .env and fill in real values. NEVER commit .env.

APP_ENV=development
LOG_FORMAT=pretty

FLASK_APP=run.py
FLASK_DEBUG=1
SECRET_KEY=my_super_secret_key_123456789abcdefghijklmnopqrstuvwxyz
JWT_SECRET_KEY=my_jwt_secret_abcdefghijklmnopqrstuvwxyz123456789
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=900
JWT_REFRESH_TOKEN_EXPIRES_SECONDS=604800

DATABASE_URL=sqlite:////Users/rohitsah/code/bharatseva-ai/backend/data/bharatseva.db

BCRYPT_COST=12
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

WATSONX_API_KEY=your WATSONX_API_KEY
WATSONX_PROJECT_ID= your WATSONX_PROJECT_ID
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_CHAT=ibm/granite-4-h-small
WATSONX_MODEL_INSTRUCT=ibm/granite-4-h-small
WATSONX_TIMEOUT_SECONDS=15

CACHE_TYPE=SimpleCache
CACHE_DEFAULT_TIMEOUT=300

UPLOAD_FOLDER=./data/uploads
MAX_CONTENT_LENGTH=10485760

RATELIMIT_STORAGE_URI=memory://

VERSION=1.0.0
GIT_SHA=local
